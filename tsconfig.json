{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "target": "ES6",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": false,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "typeRoots": ["./types", "./node_modules/@types"],
    "module": "esnext",
    // Important: switch "moduleResolution" from "bundler" to "node" for better compatibility
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "declaration": false,
    "forceConsistentCasingInFileNames": true,

    // Keep baseUrl as "./src"
    "baseUrl": "./src",

    // Because baseUrl is "./src", remove extra "src/" in each path. 
    // E.g. "@hooks/*" -> "hooks/*" means "./src/hooks/*"
    "paths": {
      "@/*": ["*"],
      "@components/*": ["components/*"],
      "@hooks/*": ["hooks/*"],
      "@services/*": ["services/*"],
      "@styles/*": ["styles/*"],
      "@types/*": ["types/*"],
      "@utils/*": ["utils/*"],
      "@features/*": ["features/*"],
      "@store/*": ["store/*"]
    },

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
